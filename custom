local function syncKaitunSetting(key, value)
    local cfg = ENV.Kaitun or _G.Kaitun
    if type(cfg) == "table" then
        cfg[key] = value
    end
end

local function cleanKaitunText(value)
    local raw = tostring(value or "")
    raw = raw:gsub("94p", " ")
    raw = raw:gsub("%s+", " ")
    raw = raw:gsub("^%s+", ""):gsub("%s+$", "")
    return raw
end

local function formatPercentNumber(value)
    local numberValue = tonumber(value) or 0
    if math.abs(numberValue - math.floor(numberValue)) < 0.000001 then
        return tostring(math.floor(numberValue))
    end
    local textValue = string.format("%.2f", numberValue)
    return textValue:gsub("0+$", ""):gsub("%.$", "")
end

local function applySelectRangeValues(minValue, maxValue, displayText)
    local minNumber = tonumber(minValue)
    local maxNumber = tonumber(maxValue)
    if not minNumber or not maxNumber then
        return false
    end

    minNumber = math.clamp(minNumber, 0, 100)
    maxNumber = math.clamp(maxNumber, 0, 100)

    if minNumber > maxNumber then
        minNumber, maxNumber = maxNumber, minNumber
    end

    Runtime.SelectMin = minNumber
    Runtime.SelectMax = maxNumber
    Runtime.SelectThreshold = maxNumber
    Runtime.SelectText = displayText or (formatPercentNumber(minNumber) .. "-" .. formatPercentNumber(maxNumber) .. "%")

    syncKaitunSetting("Select Type (%)", Runtime.SelectText)
    syncKaitunSetting("Select Min (%)", Runtime.SelectMin)
    syncKaitunSetting("Select Max (%)", Runtime.SelectMax)
    return true
end

local function parsePercentRangeText(rawText)
    local textValue = cleanKaitunText(rawText)
    local minText, maxText = textValue:match("(%d+%.?%d*)%s*[%-%–]%s*(%d+%.?%d*)")
    if minText and maxText then
        return tonumber(minText), tonumber(maxText)
    end
    return nil, nil
end

local function applySelectTypeValue(selectedType)
    if selectedType == nil then
        return false
    end

    local raw = cleanKaitunText(selectedType)
    local rangeMin, rangeMax = parsePercentRangeText(raw)
    if rangeMin and rangeMax then
        return applySelectRangeValues(rangeMin, rangeMax)
    end

    local asNumber = tonumber(raw)

    for _, option in ipairs(JUNKYARD_SELECT_OPTIONS) do
        if raw == option.Text or asNumber == option.Value then
            return applySelectRangeValues(0, option.Value, option.Text)
        end
    end

    local extracted = tonumber(raw:match("(%d+%.?%d*)"))
    if extracted then
        for _, option in ipairs(JUNKYARD_SELECT_OPTIONS) do
            if extracted == option.Value then
                return applySelectRangeValues(0, option.Value, option.Text)
            end
        end

        return applySelectRangeValues(0, extracted, "< " .. tostring(extracted) .. "%")
    end

    return false
end

local function applyKaitunConfig()
    local cfg = ENV.Kaitun or _G.Kaitun
    if type(cfg) ~= "table" then return end

    if cfg["Anri AFK"] ~= nil and cfg["Anti AFK"] == nil then
        cfg["Anti AFK"] = cfg["Anri AFK"]
        cfg["Anri AFK"] = nil
    end

    if cfg["Auto Farm"] ~= nil then
        Runtime.Enabled = cfg["Auto Farm"] == true
    end

    local moveMode = cfg["Movement Mode"] or cfg.MovementMode or cfg["Move Mode"]
    if moveMode == "Tween" or moveMode == "Teleport" then
        Runtime.MovementMode = moveMode
        Runtime.MovementText = moveMode
    else
        Runtime.MovementMode = "Tween"
        Runtime.MovementText = "Tween"
        syncKaitunSetting("Movement Mode", "Tween")
    end

    local esp = cfg["Car ESP"]
    if esp == nil then esp = cfg.CarESP end
    if esp ~= nil then
        Runtime.CarEspEnabled = esp == true
    end

    local repair100 = cfg["Repair 100%"]
    if repair100 == nil then repair100 = cfg.Repair100 end
    if repair100 ~= nil then
        Runtime.Repair100Enabled = repair100 == true
    end

    local antiAfk = cfg["Anti AFK"]
    if antiAfk == nil then antiAfk = cfg.AntiAFK end
    if antiAfk ~= nil then
        Runtime.AntiAfkEnabled = antiAfk == true
    end

    local selectedType = cfg["Select Type (%)"] or cfg.SelectType or cfg["Car Percent"]
    applySelectTypeValue(selectedType)

    local minCfg = cfg["Select Min (%)"] or cfg.SelectMin or cfg["Min Percent"]
    local maxCfg = cfg["Select Max (%)"] or cfg.SelectMax or cfg["Max Percent"]
    if minCfg ~= nil and maxCfg ~= nil then
        applySelectRangeValues(minCfg, maxCfg)
    end

    -- Car Paint Config
    local carPaint = cfg["Car Paint"]
    if carPaint == nil then carPaint = cfg.CarPaint end
    if carPaint ~= nil then
        Runtime.CarPaintEnabled = carPaint == true
    end

    local paintType = cfg["Paint Type"] or cfg.PaintType
    if paintType and table.find(PAINT_TYPE_OPTIONS, paintType) then
        Runtime.CarPaintType = paintType
    end
end

applyKaitunConfig()

function Runtime.Add(conn)
    table.insert(Runtime.Connections, conn)
    return conn
end

function Runtime.Destroy()
    Runtime.Alive   = false
    Runtime.Enabled = false
    Runtime.Thread  += 1

    pcall(function()
        local vehicles = workspace:FindFirstChild("Vehicles")
        if vehicles then
            for _, model in ipairs(vehicles:GetChildren()) do
                if model:IsA("Model") then
                    local esp = model:FindFirstChild(JUNKYARD_ESP_NAME)
                    if esp then esp:Destroy() end
                    local tag = model:FindFirstChild(JUNKYARD_TAG_NAME)
                    if tag then tag:Destroy() end
                end
            end
        end
    end)

    for _, c in ipairs(Runtime.Connections) do
        pcall(function()
            if typeof(c) == "RBXScriptConnection" then
                c:Disconnect()
            elseif typeof(c) == "Instance" then
                c:Destroy()
            elseif type(c) == "function" then
                c()
            elseif type(c) == "table" and c.Destroy then
                c:Destroy()
            end
        end)
    end

    local g = PG:FindFirstChild(GUI_NAME)
    if g then g:Destroy() end
    ENV[RUNTIME_KEY] = nil
end

